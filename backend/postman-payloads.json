        "cost": 35,
        "duration": 120,
        "scheduledAt": "2026-06-02T18:00:00.000Z"
      }
    },
    "removeFromStop": {
      "method": "DELETE",
      "url": "/api/stops/:stopId/activities/:activityId"
    }
  },
