{
  "auth": {
    "register": {
      "method": "POST",
      "url": "/api/auth/register",
      "formData": {
        "photo": "image file optional",
        "firstName": "Aarav",
        "lastName": "Shah",
        "email": "aarav@example.com",
        "phoneNumber": "+919999999999",
        "city": "Mumbai",
        "country": "India",
        "password": "Password@123",
        "additionalInfo": "Budget traveler"
      }
    },
    "login": {
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "aarav@example.com",
        "password": "Password@123"
      }
    },
    "logout": {
      "method": "POST",
      "url": "/api/auth/logout"
    }
  },
  "trips": {
    "create": {
      "method": "POST",
      "url": "/api/trips",
      "body": {
        "name": "Paris and Rome Adventure",
        "description": "Museums, food walks, and easy transport",
        "startDate": "2026-06-01T00:00:00.000Z",
        "endDate": "2026-06-08T00:00:00.000Z",
        "isPublic": false
      }
    },
    "list": {
      "method": "GET",
      "url": "/api/trips/user/all?q=rome&status=UPCOMING&sort=startDate&order=asc&groupBy=status"
    },
    "detail": {
      "method": "GET",
      "url": "/api/trips/:tripId"
    },
    "update": {
      "method": "PATCH",
      "url": "/api/trips/:tripId",
      "body": {
        "name": "Paris, Rome and Florence",
        "description": "Updated trip plan",
        "startDate": "2026-06-01T00:00:00.000Z",
        "endDate": "2026-06-09T00:00:00.000Z"
      }
    },
    "status": {
      "method": "PATCH",
      "url": "/api/trips/:tripId/status",
      "body": {
        "status": "ONGOING"
      }
    },
    "share": {
      "method": "PATCH",
      "url": "/api/trips/:tripId/share",
      "body": {
        "isPublic": true,
        "caption": "A compact Europe plan with food and museums."
      }
    },
    "delete": {
      "method": "DELETE",
      "url": "/api/trips/:tripId"
    },
    "suggestions": {
      "method": "GET",
      "url": "/api/trips/suggestions?q=paris&take=10"
    },
    "preplanned": {
      "method": "GET",
      "url": "/api/trips/preplanned?q=europe&take=12"
    },
    "clonePreplanned": {
      "method": "POST",
      "url": "/api/trips/preplanned/:tripId/clone"
    },
    "coverUpload": {
      "method": "PATCH",
      "url": "/api/trips/:tripId/cover",
      "formData": {
        "coverImage": "image file"
      }
    }
  },
  "stops": {
    "add": {
      "method": "POST",
      "url": "/api/trips/:tripId/stops",
      "body": {
        "cityId": "city_id",
        "startDate": "2026-06-01T00:00:00.000Z",
        "endDate": "2026-06-03T00:00:00.000Z",
        "order": 0,
        "notes": "Arrive and check in."
      }
    },
    "list": {
      "method": "GET",
      "url": "/api/trips/:tripId/stops"
    },
    "update": {
      "method": "PATCH",
      "url": "/api/stops/:stopId",
      "body": {
        "cityId": "city_id",
        "startDate": "2026-06-02T00:00:00.000Z",
        "endDate": "2026-06-04T00:00:00.000Z",
        "order": 1
      }
    },
    "reorder": {
      "method": "PATCH",
      "url": "/api/trips/:tripId/stops/reorder",
      "body": {
        "stops": [
          {
            "stopId": "stop_id_1",
            "order": 0
          },
          {
            "stopId": "stop_id_2",
            "order": 1
          }
        ]
      }
    },
    "delete": {
      "method": "DELETE",
      "url": "/api/stops/:stopId"
    }
  },
  "activities": {
    "search": {
      "method": "GET",
      "url": "/api/activities/search?q=museum&cityId=:cityId&category=CULTURE&take=20"
